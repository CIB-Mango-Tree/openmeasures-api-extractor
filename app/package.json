{
  "name": "mango-tree-api-extractor",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "compile": "pkg -c ./package.json ./build/index.mjs",
    "build": "tsc --noEmit && esbuild index.ts --bundle --platform=node --format=cjs --outfile=build/index.mjs"
  },
  "keywords": [],
  "author": "CIB Mango Tree",
  "license": "MIT",
  "packageManager": "pnpm@10.7.0",
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@yao-pkg/pkg": "^6.10.1",
    "esbuild": "^0.27.0",
    "typescript": "^5.9.3"
  },
  "pkg": {
    "assets": [
      "./bundle/.output/**/*",
      "./bundle/.nitro/**/*",
      "./bundle/.tanstack/**/*",
      "./bundle/dist/**/*"
    ],
    "targets": [
      "node22"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "appdirsjs": "^1.2.7",
    "chalk": "^5.6.2"
  }
}
